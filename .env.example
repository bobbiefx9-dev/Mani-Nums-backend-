# Copy this file to .env and fill in real values. Never commit .env.

# From twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Port for the local API server
PORT=4000

# Optional. Where the SQLite file lives. Leave unset locally (defaults to
# backend/farline.db). In production, point this at a persistent disk —
# see render.yaml, which mounts one automatically.
# DB_PATH=/opt/render/project/src/data/farline.db

# Comma-separated list of origins allowed to call this API
ALLOWED_ORIGIN=http://localhost:5500

# From dashboard.stripe.com/test/apikeys (use test keys until you're ready to go live)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# From the Stripe CLI or Dashboard webhook endpoint config (see README)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Where Stripe should send the user after checkout
SITE_URL=http://localhost:5500

# Any long random string — used to sign login sessions (JWTs).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# SMTP settings for sending verification/password-reset emails. Any provider
# works (SendGrid, Mailgun, Postmark, even Gmail SMTP for quick testing).
# For local testing without a real inbox, use https://ethereal.email — it
# gives you free throwaway SMTP credentials and a web inbox to view mail.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="Mani Nums <no-reply@maninums.example.com>"
